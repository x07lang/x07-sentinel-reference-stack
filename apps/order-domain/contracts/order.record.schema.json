{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "order.record",
  "type": "object",
  "required": [
    "order_id",
    "status",
    "customer_id",
    "currency",
    "total_minor",
    "created_at"
  ],
  "properties": {
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "received",
        "projected",
        "reconciled",
        "failed"
      ]
    },
    "customer_id": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "total_minor": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_projection_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_reconciled_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
